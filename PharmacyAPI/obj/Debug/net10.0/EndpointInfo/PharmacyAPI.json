  "components": {
    "schemas": {
      "CreateMedicineDto": {
        "required": [
          "category",
          "name",
          "price",
          "stockQuantity"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "description": {
            "maxLength": 1000,
            "type": "string",
            "nullable": true
          },
          "category": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "stockQuantity": {
            "type": "integer",
            "format": "int32"
          },
          "imageUrl": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          },
          "requiresPrescription": {
            "type": "boolean"
          },
          "dosage": {
            "maxLength": 100,
            "type": "string",
            "nullable": true
          },
          "packaging": {
            "maxLength": 100,
            "type": "string",
            "nullable": true
          },
          "manufacturer": {
            "maxLength": 200,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateOrderDto": {
        "required": [
          "items"
        ],
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrderItemDto"
            }
          },
          "prescriptionId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "shippingAddress": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "OrderItemDto": {
        "required": [
          "medicineId",
          "quantity"
        ],
        "type": "object",
        "properties": {
          "medicineId": {
            "type": "integer",
            "format": "int32"
          },
          "quantity": {
            "maximum": 100,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "ProcessPaymentDto": {
        "required": [
          "method"
        ],
        "type": "object",
        "properties": {
          "method": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RegisterDto": {
        "required": [
          "email",
          "name",
          "password"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "email": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 6,
            "type": "string"
          },
          "phone": {
            "maxLength": 15,
            "type": "string",
            "nullable": true
          },
          "address": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ReviewPrescriptionDto": {
        "required": [
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "minLength": 1,
            "type": "string"
          },
          "reason": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateMedicineDto": {
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 200,
            "type": "string",
            "nullable": true
          },
          "description": {
            "maxLength": 1000,
            "type": "string",
            "nullable": true
          },
          "category": {
            "maxLength": 100,
            "type": "string",
            "nullable": true
          },
          "price": {
            "type": "number",
            "format": "double",
            "nullable": true
          },
          "stockQuantity": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "imageUrl": {
            "maxLength": 500,
            "type": "string",
            "nullable": true
          },
          "requiresPrescription": {
            "type": "boolean",
            "nullable": true
          },
          "isAvailable": {
            "type": "boolean",
            "nullable": true
          },
          "dosage": {
            "maxLength": 100,
            "type": "string",
            "nullable": true
          },
          "packaging": {
            "maxLength": 100,
            "type": "string",
            "nullable": true
          },
          "manufacturer": {
            "maxLength": 200,
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdateOrderStatusDto": {
        "required": [
          "status"
        ],
        "type": "object",
        "properties": {
          "status": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Enter your JWT token",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
